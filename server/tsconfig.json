{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    // Keep all source files inside src
    "rootDir": "src",
    "outDir": "dist",

    // Compatibility and type safety
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["src/**/*", "cookie-parser"],
  "exclude": [
    "node_modules",
    "generated",
    "prisma.config.ts" // config file outside src
  ]
}
